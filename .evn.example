# Environment Configuration

# Application
APP_NAME=cybersec-toolkit
APP_VERSION=1.0.0
DEBUG=false

# Security
SECURE_COOKIES=true
CSRF_ENABLED=true
SSL_REDIRECT=true

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cybersec
DB_USER=dev
DB_PASSWORD=dev-password
DB_POOL_SIZE=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Keys (optional)
API_KEY_SHODAN=
API_KEY_VIRUSTOTAL=
API_KEY_CENSYS=

# Features
ENABLE_PAYLOAD_GENERATOR=true
ENABLE_PORT_SCANNER=true
ENABLE_SUBDOMAIN_ENUM=true
ENABLE_HASH_CRACKER=true

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=30
RESULT_CACHE_TTL=3600
